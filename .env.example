# ── LLM ─────────────────────────────────────────────
LLM_MODE=free                       # free (Ollama, local) | deep (cloud API)
OLLAMA_BASE_URL=http://localhost:11434
# 4GB VRAM: qwen3:8b = better quality, partial CPU offload (slower);
#           qwen3:4b = fits VRAM, faster, blunter Arabic. You already have 8b.
OLLAMA_MODEL=qwen3:8b
# Optional deep mode (cloud brain) — leave blank to stay fully local
DEEP_API_PROVIDER=                  # deepseek | gemini | claude
DEEP_API_KEY=

# ── Voice (ElevenLabs) ──────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_TTS_MODEL=eleven_v3

# ── Web search ──────────────────────────────────────
TAVILY_API_KEY=
BRAVE_API_KEY=

# ── Memory / DB (Phase 2) ───────────────────────────
DATABASE_URL=postgresql://companion:companion@localhost:5432/companion
EMBEDDING_MODEL=BAAI/bge-m3

# ── Persona ─────────────────────────────────────────
OWNER_NAME=Eyad
DEFAULT_PERSONA=jarvis               # jarvis | friday | tars | case | auto

# ── Safety: Windows tool (Phase 5) ──────────────────
WINDOWS_TOOL_REQUIRE_CONFIRM=true
WINDOWS_TOOL_WORKDIR=./workspace
WINDOWS_TOOL_TIMEOUT_SEC=30
WINDOWS_TOOL_OUTPUT_CAP=20000

# ── Safety: Browser tool (Phase 4) ──────────────────
BROWSER_HEADLESS=false
BROWSER_DOMAIN_ALLOWLIST=            # comma-separated; empty = all (still untrusted)

# ── Server ──────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
